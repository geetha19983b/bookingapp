{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "backend.ts",
    "db.ts",
    "routes/**/*.ts",
    "services/**/*.ts",
    "schemas/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
