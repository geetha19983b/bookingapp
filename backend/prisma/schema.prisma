// Prisma schema file for BookKeeping App
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Master Data: Chart of Accounts
model Account {
  id                      Int       @id @default(autoincrement())
  accountId               String?   @unique @map("account_id") @db.VarChar(50)  // External system ID (e.g., Zoho ID)
  accountType             String    @map("account_type") @db.VarChar(50)        // income, expense, asset, liability, equity
  accountName             String    @map("account_name") @db.VarChar(200)
  accountCode             String?   @map("account_code") @db.VarChar(20)
  parentAccountId         Int?      @map("parent_account_id")                    // For hierarchical accounts
  
  // Account Details
  description             String?   @db.Text
  accountHint             String?   @map("account_hint") @db.Text               // User-friendly description
  depth                   Int       @default(0)                                  // Hierarchy depth (0 = root)
  
  // Classification
  accountTypeInt          Int?      @map("account_type_int")                     // Numeric type code
  scheduleBalanceSheetCategory String? @map("schedule_balancesheet_category") @db.VarChar(100)
  scheduleProfitAndLossCategory String? @map("schedule_profit_and_loss_category") @db.VarChar(100)
  
  // Flags
  isTaxAccount            Boolean   @default(false) @map("is_tax_account")
  isDefault               Boolean   @default(false) @map("is_default")
  isPrimaryAccount        Boolean   @default(false) @map("is_primary_account")
  isRootAccountWithChild  Boolean   @default(false) @map("is_root_account_with_child")
  
  // Status and Metadata
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  createdBy               String?   @map("created_by") @db.VarChar(100)
  updatedBy               String?   @map("updated_by") @db.VarChar(100)
  
  // Relations
  parentAccount           Account?  @relation("AccountHierarchy", fields: [parentAccountId], references: [id], onDelete: Restrict)
  childAccounts           Account[] @relation("AccountHierarchy")
  itemsSales              Item[]    @relation("SalesAccount")
  itemsPurchase           Item[]    @relation("PurchaseAccount")
  
  @@map("accounts")
  @@index([accountId])
  @@index([accountType])
  @@index([accountName])
  @@index([parentAccountId])
  @@index([isActive])
  @@index([isTaxAccount])
}

// Master Data: Units of Measurement (UQC - Unique Quantity Code)
model Unit {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(10)       // UQC code (e.g., "PCS", "KGS", "BOX")
  name        String    @db.VarChar(100)              // Full name (e.g., "Pieces", "Kilograms")
  description String?   @db.VarChar(255)              // Optional description
  
  // Status and Metadata
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String?   @map("created_by") @db.VarChar(100)
  updatedBy   String?   @map("updated_by") @db.VarChar(100)
  
  // Relations
  items                 Item[]
  vendorItemsHistory    VendorItemHistory[]
  
  @@map("units")
  @@index([code])
  @@index([isActive])
}

model Vendor {
  id                      Int       @id @default(autoincrement())
  companyName             String?   @map("company_name") @db.VarChar(255)
  displayName             String    @unique @map("display_name") @db.VarChar(255)
  
  // Contact Details
  email                   String?   @db.VarChar(255)
  workPhone               String?   @map("work_phone") @db.VarChar(20)
  mobilePhone             String?   @map("mobile_phone") @db.VarChar(20)
  
  // Billing Address
  billingAddressLine1     String?   @map("billing_address_line1") @db.VarChar(255)
  billingAddressLine2     String?   @map("billing_address_line2") @db.VarChar(255)
  billingCity             String?   @map("billing_city") @db.VarChar(100)      // City name (no standard code)
  billingState            String?   @map("billing_state") @db.VarChar(10)      // State ISO code (e.g., "NY", "MH")
  billingCountry          String?   @map("billing_country") @db.VarChar(2)     // Country ISO2 code (e.g., "US", "IN")
  billingZipCode          String?   @map("billing_zip_code") @db.VarChar(20)
  
  // Shipping Address
  shippingAddressLine1    String?   @map("shipping_address_line1") @db.VarChar(255)
  shippingAddressLine2    String?   @map("shipping_address_line2") @db.VarChar(255)
  shippingCity            String?   @map("shipping_city") @db.VarChar(100)     // City name (no standard code)
  shippingState           String?   @map("shipping_state") @db.VarChar(10)     // State ISO code (e.g., "NY", "MH")
  shippingCountry         String?   @map("shipping_country") @db.VarChar(2)    // Country ISO2 code (e.g., "US", "IN")
  shippingZipCode         String?   @map("shipping_zip_code") @db.VarChar(20)
  
  // GST & Tax Information
  gstTreatment            String?   @map("gst_treatment") @db.VarChar(100)
  gstin                   String?   @db.VarChar(15)
  sourceOfSupply          String?   @map("source_of_supply") @db.VarChar(100)
  pan                     String?   @db.VarChar(10)
  
  // Business Information
  isMsmeRegistered        Boolean   @default(false) @map("is_msme_registered")
  currency                String?   @default("INR") @db.VarChar(3)
  openingBalance          Decimal   @default(0.00) @map("opening_balance") @db.Decimal(15, 2)
  paymentTerms            String?   @default("Due on Receipt") @map("payment_terms") @db.VarChar(100)
  
  // Bank Details
  bankName                String?   @map("bank_name") @db.VarChar(255)
  bankAccountNumber       String?   @map("bank_account_number") @db.VarChar(50)
  bankIfscCode            String?   @map("bank_ifsc_code") @db.VarChar(11)
  bankBranch              String?   @map("bank_branch") @db.VarChar(255)
  
  // Additional Information
  remarks                 String?   @db.Text
  customFields            Json?     @map("custom_fields")
  reportingTags           String[]  @default([]) @map("reporting_tags")
  
  // Status and Metadata
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  createdBy               String?   @map("created_by") @db.VarChar(100)
  updatedBy               String?   @map("updated_by") @db.VarChar(100)
  
  // Relations
  contactPersons          ContactPerson[]
  itemsPreferred          Item[]               @relation("PreferredVendor")
  vendorItemsHistory      VendorItemHistory[]
  
  @@map("vendors")
  @@index([displayName])
  @@index([email])
  @@index([isActive])
  @@index([createdAt])
}

model Item {
  id                        Int       @id @default(autoincrement())
  
  // Basic Information
  itemType                  String    @map("item_type") @db.VarChar(20)
  name                      String    @db.VarChar(255)
  sku                       String?   @unique @db.VarChar(100)
  unitId                    Int?      @map("unit_id")
  unit                      String?   @db.VarChar(50)              // Deprecated: kept for backward compatibility
  hsnCode                   String?   @map("hsn_code") @db.VarChar(20)
  
  // Tax Information
  taxPreference             String    @default("taxable") @map("tax_preference") @db.VarChar(50)
  intraStateTaxRate         String?   @map("intra_state_tax_rate") @db.VarChar(50)
  intraStateTaxPercentage   Decimal?  @map("intra_state_tax_percentage") @db.Decimal(5, 2)
  interStateTaxRate         String?   @map("inter_state_tax_rate") @db.VarChar(50)
  interStateTaxPercentage   Decimal?  @map("inter_state_tax_percentage") @db.Decimal(5, 2)
  
  // Sales Information
  isSellable                Boolean   @default(true) @map("is_sellable")
  sellingPrice              Decimal?  @map("selling_price") @db.Decimal(15, 2)
  salesAccountId            Int?      @map("sales_account_id")
  salesAccount              String?   @map("sales_account") @db.VarChar(100)    // Deprecated: kept for backward compatibility
  salesDescription          String?   @map("sales_description") @db.Text
  
  // Purchase Information
  isPurchasable             Boolean   @default(true) @map("is_purchasable")
  costPrice                 Decimal?  @map("cost_price") @db.Decimal(15, 2)
  purchaseAccountId         Int?      @map("purchase_account_id")
  purchaseAccount           String?   @map("purchase_account") @db.VarChar(100) // Deprecated: kept for backward compatibility
  purchaseDescription       String?   @map("purchase_description") @db.Text
  preferredVendorId         Int?      @map("preferred_vendor_id")
  
  // Inventory Management
  trackInventory            Boolean   @default(false) @map("track_inventory")
  openingStock              Decimal   @default(0) @map("opening_stock") @db.Decimal(15, 2)
  openingStockRate          Decimal   @default(0) @map("opening_stock_rate") @db.Decimal(15, 2)
  reorderLevel              Decimal?  @map("reorder_level") @db.Decimal(15, 2)
  
  // Images
  imageUrl                  String?   @map("image_url") @db.VarChar(500)
  imageUrls                 String[]  @map("image_urls")
  
  // Additional Information
  customFields              Json?     @map("custom_fields")
  tags                      String[]
  
  // Status and Metadata
  isActive                  Boolean   @default(true) @map("is_active")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  createdBy                 String?   @map("created_by") @db.VarChar(100)
  updatedBy                 String?   @map("updated_by") @db.VarChar(100)
  
  // Relations
  preferredVendor           Vendor?   @relation("PreferredVendor", fields: [preferredVendorId], references: [id], onDelete: SetNull)
  unitRef                   Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  salesAccountRef           Account?  @relation("SalesAccount", fields: [salesAccountId], references: [id], onDelete: SetNull)
  purchaseAccountRef        Account?  @relation("PurchaseAccount", fields: [purchaseAccountId], references: [id], onDelete: SetNull)
  vendorItemsHistory        VendorItemHistory[]
  
  @@map("items")
  @@index([name])
  @@index([sku])
  @@index([itemType])
  @@index([hsnCode])
  @@index([unitId])
  @@index([salesAccountId])
  @@index([purchaseAccountId])
  @@index([preferredVendorId])
  @@index([isActive])
  @@index([isSellable])
  @@index([isPurchasable])
  @@index([createdAt])
}

model ContactPerson {
  id          Int       @id @default(autoincrement())
  vendorId    Int       @map("vendor_id")
  
  // Personal Information
  salutation  String?   @db.VarChar(10)
  firstName   String?   @map("first_name") @db.VarChar(100)
  lastName    String?   @map("last_name") @db.VarChar(100)
  email       String?   @db.VarChar(255)
  workPhone   String?   @map("work_phone") @db.VarChar(20)
  mobilePhone String?   @map("mobile_phone") @db.VarChar(20)
  
  // Additional Information
  designation String?   @db.VarChar(100)
  department  String?   @db.VarChar(100)
  isPrimary   Boolean   @default(false) @map("is_primary")
  
  // Metadata
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  @@map("contact_persons")
  @@index([vendorId])
  @@index([email])
  @@index([isPrimary])
}

model VendorItemHistory {
  id                  Int       @id @default(autoincrement())
  vendorId            Int       @map("vendor_id")
  itemId              Int       @map("item_id")
  
  // Purchase Information
  purchasePrice       Decimal   @map("purchase_price") @db.Decimal(15, 2)
  quantity            Decimal?  @db.Decimal(15, 2)
  unitId              Int?      @map("unit_id")
  unit                String?   @db.VarChar(50)              // Deprecated: kept for backward compatibility
  
  // Reference Information
  purchaseOrderNumber String?   @map("purchase_order_number") @db.VarChar(100)
  invoiceNumber       String?   @map("invoice_number") @db.VarChar(100)
  purchaseDate        DateTime? @map("purchase_date") @db.Date
  
  // Additional Details
  notes               String?   @db.Text
  
  // Metadata
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  
  // Relations
  vendor              Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  item                Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unitRef             Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  
  @@map("vendor_items_history")
  @@index([vendorId])
  @@index([itemId])
  @@index([unitId])
  @@index([purchaseDate])
  @@index([vendorId, itemId, purchaseDate])
}

// Master Data: Customers
model Customer {
  id                      Int       @id @default(autoincrement())
  
  // Customer Type
  customerType            String    @default("business") @map("customer_type") @db.VarChar(20) // business, individual
  
  // Primary Contact (for Individual customers)
  salutation              String?   @db.VarChar(10)
  firstName               String?   @map("first_name") @db.VarChar(100)
  lastName                String?   @map("last_name") @db.VarChar(100)
  
  // Company Information (for Business customers)
  companyName             String?   @map("company_name") @db.VarChar(255)
  displayName             String    @unique @map("display_name") @db.VarChar(255)
  
  // Contact Details
  email                   String?   @db.VarChar(255)
  workPhone               String?   @map("work_phone") @db.VarChar(20)
  mobilePhone             String?   @map("mobile_phone") @db.VarChar(20)
  
  // Language Preference
  customerLanguage        String?   @default("English") @map("customer_language") @db.VarChar(50)
  
  // Billing Address
  billingAttention        String?   @map("billing_attention") @db.VarChar(255)
  billingAddressLine1     String?   @map("billing_address_line1") @db.VarChar(255)
  billingAddressLine2     String?   @map("billing_address_line2") @db.VarChar(255)
  billingCity             String?   @map("billing_city") @db.VarChar(100)
  billingState            String?   @map("billing_state") @db.VarChar(10)      // State ISO code (e.g., "NY", "MH")
  billingCountry          String?   @map("billing_country") @db.VarChar(2)     // Country ISO2 code (e.g., "US", "IN")
  billingZipCode          String?   @map("billing_zip_code") @db.VarChar(20)
  billingPhone            String?   @map("billing_phone") @db.VarChar(20)
  billingFax              String?   @map("billing_fax") @db.VarChar(20)
  
  // Shipping Address
  shippingAttention       String?   @map("shipping_attention") @db.VarChar(255)
  shippingAddressLine1    String?   @map("shipping_address_line1") @db.VarChar(255)
  shippingAddressLine2    String?   @map("shipping_address_line2") @db.VarChar(255)
  shippingCity            String?   @map("shipping_city") @db.VarChar(100)
  shippingState           String?   @map("shipping_state") @db.VarChar(10)     // State ISO code (e.g., "NY", "MH")
  shippingCountry         String?   @map("shipping_country") @db.VarChar(2)    // Country ISO2 code (e.g., "US", "IN")
  shippingZipCode         String?   @map("shipping_zip_code") @db.VarChar(20)
  shippingPhone           String?   @map("shipping_phone") @db.VarChar(20)
  shippingFax             String?   @map("shipping_fax") @db.VarChar(20)
  
  // GST & Tax Information
  gstTreatment            String?   @map("gst_treatment") @db.VarChar(100)
  gstin                   String?   @db.VarChar(15)
  placeOfSupply           String?   @map("place_of_supply") @db.VarChar(100)
  pan                     String?   @db.VarChar(10)
  taxPreference           String    @default("taxable") @map("tax_preference") @db.VarChar(20) // taxable, tax_exempt
  
  // Business Information
  currency                String?   @default("INR") @db.VarChar(3)
  openingBalance          Decimal   @default(0.00) @map("opening_balance") @db.Decimal(15, 2)
  paymentTerms            String?   @default("Due on Receipt") @map("payment_terms") @db.VarChar(100)
  
  // Portal Access
  enablePortal            Boolean   @default(false) @map("enable_portal")
  
  // Documents & Files
  documentUrls            String[]  @default([]) @map("document_urls")
  
  // Additional Information
  remarks                 String?   @db.Text
  customFields            Json?     @map("custom_fields")
  reportingTags           String[]  @default([]) @map("reporting_tags")
  
  // Status and Metadata
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  createdBy               String?   @map("created_by") @db.VarChar(100)
  updatedBy               String?   @map("updated_by") @db.VarChar(100)
  
  // Relations
  contactPersons          CustomerContactPerson[]
  
  @@map("customers")
  @@index([displayName])
  @@index([email])
  @@index([customerType])
  @@index([isActive])
  @@index([createdAt])
}

// Contact Persons for Customers
model CustomerContactPerson {
  id          Int       @id @default(autoincrement())
  customerId  Int       @map("customer_id")
  
  // Personal Information
  salutation  String?   @db.VarChar(10)
  firstName   String?   @map("first_name") @db.VarChar(100)
  lastName    String?   @map("last_name") @db.VarChar(100)
  email       String?   @db.VarChar(255)
  workPhone   String?   @map("work_phone") @db.VarChar(20)
  mobilePhone String?   @map("mobile_phone") @db.VarChar(20)
  
  // Additional Information
  designation String?   @db.VarChar(100)
  department  String?   @db.VarChar(100)
  isPrimary   Boolean   @default(false) @map("is_primary")
  
  // Metadata
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@map("customer_contact_persons")
  @@index([customerId])
  @@index([email])
  @@index([isPrimary])
}
